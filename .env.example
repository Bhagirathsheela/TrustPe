# Copy this to .env (gitignored) and fill in real values for local dev.

# ---- Backend (apps/api) ----
NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/trustpe
REDIS_URL=redis://localhost:6379

# JWT secrets (generate via: openssl rand -base64 32)
JWT_ACCESS_SECRET=replace-me-with-256-bit-secret
JWT_REFRESH_SECRET=replace-me-with-another-256-bit-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (email)
RESEND_API_KEY=

# Sentry
SENTRY_DSN_API=
SENTRY_DSN_ADMIN=
SENTRY_DSN_MOBILE=

# Logging
LOG_LEVEL=debug

# ---- Admin (apps/admin) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# ---- Mobile (apps/mobile) ----
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000/v1
