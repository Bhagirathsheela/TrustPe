# Admin Next.js environment.
# Copy to .env.local and fill in.
# All NEXT_PUBLIC_ vars are exposed to the browser.

# Backend API base — defaults to localhost:4000 if unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# Cloudinary cloud name — needed to render KYC document images on the
# admin review screen. Find on cloudinary.com → Dashboard.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dmrn5mcca
