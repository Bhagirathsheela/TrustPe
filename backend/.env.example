NODE_ENV=development
PORT=4000

# Database — MongoDB Atlas (production-style for local dev)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Get this from your Atlas project → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/trustpe-dev?retryWrites=true&w=majority

# Redis — optional in Sprint 1 (in-memory store used when not set).
# Required from Sprint 3 onwards (BullMQ workers + rate limiting).
# REDIS_URL=redis://localhost:6379

# JWT (generate via: openssl rand -base64 32)
JWT_ACCESS_SECRET=replace-me-with-256-bit-secret
JWT_REFRESH_SECRET=replace-me-with-another-256-bit-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Cloudinary — required from Sprint 1 (KYC images, UPI screenshots, agreement PDFs)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────────────────────────────────────────────
# Email — pick ONE provider. See docs/EMAIL_PROVIDER_OPTIONS.md.
#
# Option A: SMTP via Gmail (zero cost, no domain required — best for pilot)
#   Set SMTP_HOST + SMTP_USER + SMTP_PASS below.
#   SMTP_PASS is an "app password" from https://myaccount.google.com/apppasswords
#   (requires 2FA on your Google account).
#
# Option B: Resend (needs verified domain — best for public launch)
#   Set RESEND_API_KEY only. Leave SMTP_* blank.
# ─────────────────────────────────────────────────────────────

# Option A — SMTP (Gmail example)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Option B — Resend
RESEND_API_KEY=

# Sender + reply — used by both providers.
# SMTP mode: keep EMAIL_FROM matching SMTP_USER so recipients don't see "via" warnings.
# Resend mode: EMAIL_FROM must be at your verified Resend domain.
EMAIL_FROM=TrustPe <no-reply@trustpe.in>
EMAIL_REPLY_TO=support@trustpe.in

# Sentry — optional
SENTRY_DSN=

# Logging
LOG_LEVEL=debug

# CORS allowed origins (comma-separated). Mobile dev server: 19006. Admin: 3001.
CORS_ORIGINS=http://localhost:3001,http://localhost:19006
