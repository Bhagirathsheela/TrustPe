NODE_ENV=development
PORT=4000

# Database — MongoDB Atlas (production-style for local dev)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Get this from your Atlas project → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/trustpe-dev?retryWrites=true&w=majority

# JWT (generate via: openssl rand -base64 32)
JWT_ACCESS_SECRET=replace-me-with-256-bit-secret
JWT_REFRESH_SECRET=replace-me-with-another-256-bit-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Cloudinary — required for KYC document uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────────────────────────────────────────────
# Email — Nodemailer SMTP (Gmail app password path). Zero cost,
# no DNS setup. See docs/PRODUCTION_EMAIL_SETUP.md.
#
# 1. Enable 2FA on your Google account.
# 2. Go to https://myaccount.google.com/apppasswords, create an app
#    password named "TrustPe backend". You'll get a 16-char code.
# 3. Fill SMTP_USER + SMTP_PASS below.
# 4. Set EMAIL_FROM to match SMTP_USER so Gmail doesn't add a "via" line.
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

EMAIL_FROM=TrustPe <no-reply@trustpe.in>
EMAIL_REPLY_TO=support@trustpe.in

# Sentry — optional. Currently the tracker is in stub mode regardless.
SENTRY_DSN=

# Logging
LOG_LEVEL=debug

# CORS allowed origins (comma-separated). Mobile uses native fetch (no
# CORS) so only the admin web origin matters here.
CORS_ORIGINS=http://localhost:3001,http://localhost:19006
