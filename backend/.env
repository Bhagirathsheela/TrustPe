# ─────────────────────────────────────────────────────────────
# Email — pick ONE. See docs/EMAIL_PROVIDER_OPTIONS.md.
#
# Option A: SMTP via Gmail — zero cost, no domain needed. Best for pilot.
#   1. Enable 2FA on your Google account.
#   2. Go to https://myaccount.google.com/apppasswords, create an app
#      password named "TrustPe backend". You'll get a 16-char code.
#   3. Fill SMTP_USER + SMTP_PASS below (spaces in the app password are OK).
#   4. Set EMAIL_FROM to match SMTP_USER so Gmail doesn't add "via" warnings.
#
# Option B: Resend — needs verified domain. Best for public launch.
#   Leave SMTP_* blank and only set RESEND_API_KEY.
# ─────────────────────────────────────────────────────────────

# Option A — SMTP (Gmail app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Option B — Resend (already have a key, but SMTP takes priority if configured)
RESEND_API_KEY=re_Qe1bpAf9_JFnUTg6m2TQL4JhJpssHtPRQ

# Sender + reply. For Gmail SMTP, EMAIL_FROM matching SMTP_USER avoids the
# "via" line in recipients' inboxes. For Resend, this must be at a verified domain.
EMAIL_FROM=TrustPe <onboarding@resend.dev>
EMAIL_REPLY_TO=support@trustpe.in

# Sentry — optional
SENTRY_DSN=

# Logging
LOG_LEVEL=debug

# CORS allowed origins (comma-separated). Mobile uses native fetch (no CORS) so
# only the admin web origin matters here.
CORS_ORIGINS=http://localhost:3001,http://localhost:19006
