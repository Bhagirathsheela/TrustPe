# ─────────────────────────────────────────────────────────────
# Email — Nodemailer SMTP (Gmail app password). Zero cost, no DNS.
# 1. Enable 2FA on your Google account.
# 2. Get an app password from https://myaccount.google.com/apppasswords
# 3. Fill SMTP_USER + SMTP_PASS below — REMOVE the spaces Gmail shows
#    (the real password is 16 chars, no spaces), and no quotes around it.
# 4. Set EMAIL_FROM matching SMTP_USER so Gmail doesn't add "via" warnings.
# Leave blank = stub mode (OTP prints to backend terminal).
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=bhagirathsheela001@gmail.com
SMTP_PASS=bvzzgcdnfpmckxif
# DEV ONLY — set true if your local antivirus/proxy intercepts TLS
# and you're seeing "self-signed certificate in certificate chain".
# Ignored automatically when NODE_ENV=production.
SMTP_TLS_INSECURE=true

EMAIL_FROM=TrustPe <bhagirathsheela001@gmail.com>
EMAIL_REPLY_TO=support@trustpe.in

# Sentry — optional. Currently stub-mode only.
SENTRY_DSN=

# Logging
LOG_LEVEL=debug

# CORS allowed origins (comma-separated). Mobile uses native fetch (no CORS) so
# only the admin web origin matters here.
CORS_ORIGINS=http://localhost:3001,http://localhost:19006
